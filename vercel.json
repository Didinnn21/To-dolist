{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.2"
        },
        {
            "src": "/public/build/**",
            "use": "@vercel/static"
        },
        {
            "src": "/public/css/**",
            "use": "@vercel/static"
        },
        {
            "src": "/public/js/**",
            "use": "@vercel/static"
        },
        {
            "src": "/public/favicon.ico",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(css|js|build)/(.*)",
            "dest": "/public/$1/$2"
        },
        {
            "src": "/(favicon\\.ico)",
            "dest": "/public/$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr"
    }
}
